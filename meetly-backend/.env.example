# Twilio SMS: used only when NODE_ENV is exactly "production" AND SMS_LOG_ONLY is unset/false.
# Codes in logs: set NODE_ENV=development (or anything ≠ production), OR on Railway keep NODE_ENV=production
# and set SMS_LOG_ONLY=true to force log-only SMS without changing NODE_ENV.
NODE_ENV=development
SMS_LOG_ONLY=

PORT=3000

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

JWT_SECRET=change-me

# Twilio SMS (fallback when Telegram Gateway cannot deliver). Required when real SMS is on
# (NODE_ENV=production and SMS_LOG_ONLY not truthy).
# Names must be TWILIO_* (letter O). TWILI0_* (digit zero) is ignored and breaks SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 sender number, e.g. +15551234567
TWILIO_PHONE_NUMBER=

# Telegram Gateway — OTP via Telegram app (https://gateway.telegram.org)
# If unset or empty, send-code uses SMS only.
TELEGRAM_GATEWAY_ACCESS_TOKEN=

# Set to true to always use Twilio SMS and never call Telegram Gateway (even if token is set).
VERIFICATION_SMS_ONLY=
